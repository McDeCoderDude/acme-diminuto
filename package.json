{
  "name": "acme-diminuto",
  "version": "1.0.0",
  "type": "module",
  "description": "This application creates a diminuto url from a long url and redirects when diminuto url is used.",
  "main": "server.js",
  "scripts": {
    "start": "nodemon --exec \"npx ts-node\" src/server.ts",
    "start:prod": "node dist/server.js",
    "build": "npx tsc --project ./",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "express",
    "node",
    "typescript",
    "mongodb",
    "mongoose"
  ],
  "author": {
    "name": "Danny W McKinney",
    "email": "DeCoderDude@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.2",
    "agenda": "^6.2.4",
    "body-parser": "^2.3.0",
    "bson": "^7.3.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.0",
    "shortid": "^2.2.8",
    "valid-url": "^1.0.9"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^26.0.1",
    "@types/shortid": "^2.2.0",
    "@types/supertest": "^7.2.0",
    "@types/valid-url": "^1.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
